{
  "realm": "ione",
  "enabled": true,
  "displayName": "IONe",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "clients": [
    {
      "clientId": "ione-local",
      "enabled": true,
      "publicClient": true,
      "redirectUris": ["http://localhost:3000/*"],
      "webOrigins": ["http://localhost:3000"],
      "standardFlowEnabled": true,
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "ione_role",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "ione_role",
            "claim.name": "ione_role",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "ione_coc_level",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "ione_coc_level",
            "claim.name": "ione_coc_level",
            "jsonType.label": "int",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "jsmith",
      "enabled": true,
      "email": "jsmith@ione.local",
      "firstName": "J",
      "lastName": "Smith",
      "credentials": [
        {
          "type": "password",
          "value": "jsmith",
          "temporary": false
        }
      ],
      "attributes": {
        "ione_role": ["member"],
        "ione_coc_level": ["0"]
      }
    }
  ]
}
